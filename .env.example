# Docker Compose 对外端口。默认访问 http://localhost:8088
NGINX_PORT=8088

# Postgres 容器账号。第一次本地跑默认不用改。
# 如果改了这里，下面 SQLALCHEMY_DATABASE_URI 也要同步改。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus

# API 运行配置。Docker Compose 下数据库主机名必须用 manus-postgres，不要写 localhost。
ENV=development
LOG_LEVEL=INFO
APP_CONFIG_FILEPATH=config.yaml
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus

# Redis 容器配置。当前 compose 没有配置 Redis 密码，所以 REDIS_PASSWORD 留空。
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 腾讯云 COS。使用上传文件、下载文件、浏览器截图预览时需要填。
# 只是启动服务/看页面可以先留空，但相关文件能力会不可用。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=https
COS_BUCKET=
# 当前代码基本没有使用 COS_DOMAIN，可留空。
COS_DOMAIN=

# 沙箱配置。
# SANDBOX_ADDRESS 留空：API 按任务动态创建沙箱容器，需要挂载 Docker Socket。
# SANDBOX_ADDRESS=manus-sandbox：复用 docker-compose.yml 里的固定沙箱容器，适合先跑通。
SANDBOX_ADDRESS=
SANDBOX_IMAGE=manus-sandbox
SANDBOX_NAME_PREFIX=manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
# 下面这些只有在沙箱访问外网需要代理或 Chrome 额外启动参数时才填。
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=
